{
  "name": "airhorn",
  "version": "6.0.1",
  "description": "Cloud Notification Library",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jaredwray/airhorn.git",
    "directory": "packages/airhorn"
  },
  "author": "Jared Wray <me@jaredwray.com>",
  "license": "MIT",
  "private": false,
  "scripts": {
    "lint": "biome check --write --error-on-warnings",
    "test": "pnpm lint && vitest run --coverage",
    "test:ci": "biome check --error-on-warnings && vitest run --coverage",
    "clean": "rimraf ./dist ./coverage ./node_modules ./package-lock.json ./pnpm-lock.yaml",
    "prepublishOnly": "pnpm build",
    "build:publish": "pnpm publish --access public --no-git-checks --provenance",
    "build": "tsdown"
  },
  "dependencies": {
    "cacheable": "^2.3.5",
    "ecto": "^4.8.7",
    "hookified": "^3.0.0",
    "writr": "^6.1.2"
  },
  "files": [
    "dist",
    "LICENSE"
  ]
}
